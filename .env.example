# Desktop Pet — 环境变量说明
# ==============================================
# 复制本文件为 .env（已加入 .gitignore）或在 shell profile 中设置。
#
# 不要在 .env 中提交真实的 API Key！
# 使用 .env 文件时确保已加入 .gitignore（项目已配置）。

# ─── 运行环境 ─────────────────────────────────
# PETCORE_ENV=development    # 开发环境（默认）
# PETCORE_ENV=production     # 生产环境

# ─── 数据目录 ─────────────────────────────────
# 开发环境使用独立目录，与生产环境完全隔离
PETCORE_DATA_DIR="$HOME/.desktop-pet-dev"
# 生产环境默认为 ~/.desktop-pet
# PETCORE_DATA_DIR="$HOME/.desktop-pet"

# ─── LLM API Key ──────────────────────────────
# 当 config.toml 中 llm.api_key_env 设置为 "PETCORE_API_KEY" 时读取此变量
# PETCORE_API_KEY="sk-your-key-here"

# ─── 其他可选配置 ─────────────────────────────
# PETCORE_LOG_LEVEL=debug     # 日志级别（debug/info/warn/error）
# PETCORE_LOG_FILE=           # 日志文件路径（默认 stderr）

# ─── 开发工具（可选） ─────────────────────────
# GOTIFY_URL=                 # gotify 通知地址（调试用）
