# Desktop Pet — 环境变量配置
# 复制此文件为 .env 并按需修改
# cp .env.example .env

# === LLM API Key ===
# 从环境变量读取 API Key（不在 .env 中直接写入值）
# 安全建议：使用 op run、doppler 或 macOS Keychain 管理
export LLM_API_KEY=""

# === LLM 配置（可选）===
# 默认使用 OpenAI 兼容接口
# export LLM_BASE_URL="https://api.openai.com/v1"
# export LLM_MODEL="gpt-4o-mini"

# === PetCore 数据目录（可选）===
# 默认：~/.local/share/desktop-pet
# export PETCORE_DATA_DIR="/path/to/data"

# === 调试 ===
# export RUST_LOG="info"
# export PETCORE_LOG="debug"
