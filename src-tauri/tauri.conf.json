{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "DesktopPet",
  "version": "0.0.0",
  "identifier": "com.desktop-pet.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../frontend && pnpm dev",
    "beforeBuildCommand": "cd ../frontend && pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "桌面宠物",
        "width": 300,
        "height": 400,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "focus": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "petcore-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
